  "description": "Business metrics từ ClickHouse (OLAP): số chẩn đoán, bệnh phổ biến, phân bố theo cây trồng. Dữ liệu tích lũy bền vững qua restart — khác Prometheus counter.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT toUInt64(count()) AS \"Tổng chẩn đoán\" FROM predictions",
          "refId": "A"
        }
      ],
      "title": "Số chẩn đoán (tổng tích lũy)",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT toUInt64(count()) AS \"Tổng câu hỏi RAG\" FROM chat_events",
          "refId": "A"
        }
      ],
      "title": "Câu hỏi RAG (tổng tích lũy)",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT round(avg(confidence) * 100, 1) AS \"Confidence TB (%)\" FROM predictions WHERE $__timeFilter(timestamp)",
          "refId": "A"
        }
      ],
      "title": "Confidence trung bình (theo khoảng)",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT disease, toUInt64(count()) AS \"Số ca\" FROM predictions WHERE $__timeFilter(timestamp) GROUP BY disease ORDER BY count() DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top 10 bệnh phổ biến (theo khoảng thời gian)",
      "type": "piechart"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "format": 0,
          "queryType": "timeseries",
          "rawSql": "SELECT toStartOfDay(timestamp) AS time, crop, toUInt64(count()) AS \"Số chẩn đoán\" FROM predictions WHERE $__timeFilter(timestamp) GROUP BY time, crop ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Chẩn đoán theo ngày (phân theo cây trồng)",
      "type": "timeseries"
    }
