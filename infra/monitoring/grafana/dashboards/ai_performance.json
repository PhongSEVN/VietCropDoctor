{
  "__inputs": [],
  "__elements": {},
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Vision-AI latency, accuracy, and model confidence",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "P95 latency"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(prediction_latency_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "P50 latency"
        }
      ],
      "title": "Prediction Latency",
      "description": "Độ trễ chẩn đoán ảnh: thời gian xử lý một lượt /predict (P50 = trung vị, P95 = 95% request nhanh hơn mức này).",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg(model_confidence_last)",
          "legendFormat": "Avg confidence"
        }
      ],
      "title": "Model Confidence",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"vision-ai\"}[$__rate_interval])) by (status)",
          "legendFormat": "{{ status }}"
        }
      ],
      "title": "Vision-AI Request Rate by Status",
      "description": "Tần suất request theo mã trạng thái: số request /predict mỗi giây, tách theo mã HTTP trả về (2xx thành công, 4xx/5xx lỗi).",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(ensemble_predictions_total[$__rate_interval])) by (model)",
          "legendFormat": "{{ model }}"
        }
      ],
      "title": "Ensemble Model Prediction Rate",
      "description": "Tần suất dự đoán từng model trong ensemble: số lượt dự đoán mỗi giây của từng model thành phần (EfficientNet, MobileNetV3, ResNet50, YOLOv11, ViT).",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["vision-ai", "ml"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "AI Performance",
  "uid": "ai-performance",
  "version": 1
}
