{
  "__inputs": [],
  "__elements": {},
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "RAG pipeline: Qdrant query time, Ollama generation time, BM25 hybrid search",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(rag_latency_seconds_bucket{stage=\"retrieve\"}[$__rate_interval])) by (le))",
          "legendFormat": "Qdrant P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(rag_latency_seconds_bucket{stage=\"retrieve\"}[$__rate_interval])) by (le))",
          "legendFormat": "Qdrant P50"
        }
      ],
      "title": "Qdrant Query Latency",
      "description": "Độ trễ truy vấn Qdrant (vector DB): thời gian tìm kiếm ngữ nghĩa khi trả lời câu hỏi (P50/P95). Chỉ ghi nhận cho lượt \"Hỏi thêm\" gọi trực tiếp /query — KHÔNG bao gồm bước truy hồi ngữ cảnh mà Orchestrator gọi cho mỗi lần chẩn đoán ảnh (đường retrieve-only), nên số liệu thường rất ít so với lượng truy vấn Qdrant thực tế.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(rag_latency_seconds_bucket{stage=\"llm\"}[$__rate_interval])) by (le))",
          "legendFormat": "Ollama P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(rag_latency_seconds_bucket{stage=\"llm\"}[$__rate_interval])) by (le))",
          "legendFormat": "Ollama P50"
        }
      ],
      "title": "Ollama Generation Latency",
      "description": "Độ trễ sinh câu trả lời của Ollama: thời gian LLM (Qwen 2.5) sinh câu trả lời cho lượt \"Hỏi thêm\" trong RAG Engine. Không bao gồm lệnh gọi Ollama riêng của Orchestrator để sinh khuyến nghị điều trị sau mỗi lần chẩn đoán — lệnh gọi đó hiện chưa được đo bằng Prometheus.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(rag_queries_total[$__rate_interval])) by (crop)",
          "legendFormat": "{{ crop }}"
        }
      ],
      "title": "RAG Query Rate (theo cây trồng)",
      "description": "Tần suất câu hỏi RAG mỗi giây, chia theo loại cây trồng đang được hỏi (lúa, cà phê, mía, ngô).",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(chunks_retrieved_sum[$__rate_interval])) / sum(rate(chunks_retrieved_count[$__rate_interval]))",
          "legendFormat": "Avg docs retrieved"
        }
      ],
      "title": "Avg Context Documents Retrieved",
      "description": "Số tài liệu ngữ cảnh trung bình được truy hồi: số đoạn tài liệu (chunk) trung bình mà hệ thống lấy từ Qdrant làm ngữ cảnh cho mỗi câu hỏi, sau khi rerank.",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["rag", "llm", "qdrant"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "RAG / LLM",
  "uid": "rag-llm",
  "version": 1
}
