# Copy to .env.local and adjust for your environment.
# Vite exposes VITE_* vars to the browser bundle via import.meta.env.

# Base URL of the VietCropDoctor API Gateway
VITE_API_URL=http://localhost:8000

# Base URL of Grafana (embedded observability dashboards in the Admin Console)
VITE_GRAFANA_URL=http://localhost:3001

# Training observability UIs linked from the admin Model & Retrain tab
VITE_AIRFLOW_URL=http://localhost:8090
VITE_MLFLOW_URL=http://localhost:5000
