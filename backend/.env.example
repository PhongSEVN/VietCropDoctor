# Kafka
# Inside Docker (inter-container):   kafka:29092
# From host (kafkacat, ksqlDB, etc): localhost:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:29092


# Redis
REDIS_URL=redis://redis:6379/0


# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=plant_diseases_vn
QDRANT_GRPC_PORT=6334


# Ollama / LLM
# Inside Docker:                  http://ollama:11434
# Ollama running on host (no container): http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434
LLM_BASE_URL=http://ollama:11434
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
# Use qwen2.5:3b if VRAM < 8 GB
# LLM_MODEL=qwen2.5:3b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120.0
LLM_MAX_RETRIES=2


# Vision-AI
MODEL_PATH=/service/cv/results/mobilenetv3/models/best_model.pth


# RAG Engine
KNOWLEDGE_DIR=rag/knowledge

# Embedding — intfloat/multilingual-e5-base (~1.1 GB VRAM) runs alongside the Ollama LLM
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_VECTOR_SIZE=768
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=auto          # auto | cpu | cuda | mps
EMBEDDING_CACHE_SIZE=4096

# Upgrade to bge-m3 (1024-dim) if you have VRAM headroom:
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_VECTOR_SIZE=1024


# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNK_MIN_SIZE=80


# Retrieval
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.30
RETRIEVAL_MULTI_QUERY=false


# Reranking
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_TOP_K=3


# API / CORS
APP_NAME=VietCropDoctor
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=20
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
LOG_FILE=logs/app.log


# MLflow
# Inside Docker (inter-container):  http://mlflow:5000
# From host (browser, training CLI): http://localhost:5000
MLFLOW_TRACKING_URI=http://mlflow:5000


# Secrets (change before any non-local deployment)
# SECRET_KEY=changeme-at-least-32-chars-long
# ALLOWED_HOSTS=localhost,127.0.0.1
