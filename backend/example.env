OPENAI_API_KEY=YOUR_OPENAI_KEY
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Auth service
POSTGRES_DSN=postgresql://vcdauth:secret@postgres:5432/vcd_auth
POSTGRES_PASSWORD=secret
JWT_SECRET=change-me-in-production-use-a-64-char-random-string-here

# Cookie security (set to true behind HTTPS/TLS)
COOKIE_SECURE=false

# MinIO object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_UPLOADS=vcd-uploads
MINIO_STORE_UPLOADS=false

# Orchestrator / reasoning LLM
VISION_AI_URL=http://vision-ai:8001
RAG_ENGINE_URL=http://rag-engine:8002
REASONING_MODEL=qwen2.5:7b
