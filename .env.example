# ─────────────────────────────────────────────────────────────────────────────
#  VietCropDoctor — Environment Variables
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  REQUIRED changes before running:
#    JWT_SECRET         — 64-character random string
#    POSTGRES_PASSWORD  — strong password
#    MINIO_ROOT_PASSWORD — strong password
# ─────────────────────────────────────────────────────────────────────────────


# ── Required secrets (MUST change before deployment) ─────────────────────────
JWT_SECRET=change-me-use-64-char-random-string-here-0000000000000000000000000
POSTGRES_PASSWORD=secret
MINIO_ROOT_PASSWORD=minioadmin


# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092


# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0


# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=plant_diseases_vn


# ── Ollama / LLM ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:3b
# Use qwen2.5:3b if VRAM < 8 GB
# LLM_MODEL=qwen2.5:3b
LLM_TEMPERATURE=0.2


# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_VECTOR_SIZE=768


# ── Vision-AI ─────────────────────────────────────────────────────────────────
MODEL_PATH=/service/cv/results/mobilenetv3/models/best_model.pth
# Multi-model weighted ensemble (ViT + MobileNetV3 + ResNet50 + EfficientNet-B0 + YOLO).
# Set false to fall back to the single MODEL_PATH model.
ENSEMBLE_ENABLED=true


# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql://vcdauth:secret@postgres:5432/vcd_auth


# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=vietcropdoctor
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=secret


# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_UPLOADS=vcd-uploads
# Human-verified feedback samples (corrected/confirmed labels) land here
MINIO_BUCKET_VERIFIED=vcd-verified
# Public base URL the browser uses to load stored images
MINIO_PUBLIC_URL=http://localhost:9002
# Must be "true" for images to be stored (required for feedback image copy + ETL)
MINIO_STORE_UPLOADS=false


# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000


# ── App config ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]


env_code_path = "enter your path enviroment variable here"
