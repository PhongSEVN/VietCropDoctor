<mxfile host="Electron">
  <diagram name="Page-1" id="hncupprt-ojavnbHyzEY">
    <mxGraphModel dx="1144" dy="696" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-15" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="E3ZZzQtPJ33DhWGTJoaW-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Documents&lt;/font&gt;" Document="Kho tài liệu nông nghiệp tiếng Việt — nguồn tri thức thô đầu vào của toàn pipeline." Organized="Mỗi tài liệu là một file đặt theo cây thư mục knowledge/&lt;cây trồng&gt;/&lt;tên bệnh&gt;/text.txt. Hỗ trợ định dạng .txt, .md, .pdf, .json.&#xa;  Chính cấu trúc thư mục này về sau được dùng để gắn nhãn (cây trồng, tên bệnh) cho từng đoạn." Example="File knowledge/lúa/bệnh đạo ôn lá/text.txt chứa bài viết mô tả triệu chứng, nguyên nhân (nấm Pyricularia oryzae) và cách phòng trị bệnh đạo ôn lá trên lúa.&#xa;&#xa;Và sẽ có 1 file sources.json để lưu tài liệu đó thuộc nguồn nào" id="E3ZZzQtPJ33DhWGTJoaW-1">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="220" y="50" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-16" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="E3ZZzQtPJ33DhWGTJoaW-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Loader&lt;/font&gt;" Role="Đọc file thành đối tượng Document và gắn metadata (siêu dữ liệu) cho mỗi tài liệu." Algorithm="Quét thư mục chứa doccument, bỏ qua file rỗng/không hỗ trợ. Mỗi đuôi file có hàm đọc riêng (.txt/.md đọc thẳng, .pdf trích text, .json parse). Sau khi đọc, suy ra metadata từ đường dẫn: thư mục cấp 1 → crop, thư mục cấp 2 → disease_name; đồng thời tra source_name (nguồn trích dẫn) từ file sources.json cùng thư mục." Example="knowledge/lúa/bệnh đạo ôn lá/text.txt → Document(text=&quot;...&quot;, crop=&quot;lúa&quot;, disease_name=&quot;bệnh đạo ôn lá&quot;, source_name=&quot;https://...&quot;)." id="E3ZZzQtPJ33DhWGTJoaW-2">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="220" y="160" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-17" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="E3ZZzQtPJ33DhWGTJoaW-5">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="280" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Cleaner&lt;/font&gt;" Role="Làm sạch văn bản trước khi cắt đoạn, để embedding không bị nhiễu. Không sửa bản gốc — trả về Document mới." Algorithm="Thuật toán (clean_text), 4 bước tuần tự:&#xa;  1. Chuẩn hoá Unicode về NFC (để ký tự tiếng Việt có dấu được biểu diễn thống nhất).&#xa;  2. Xoá ký tự điều khiển không in được (loại Cc, Cf), nhưng giữ \n, \t, \r.&#xa;  3. Gộp khoảng trắng: nhiều dấu cách/tab → 1 dấu cách; 3+ dòng trống → 2 dòng.&#xa;  4. Cắt khoảng trắng đầu/cuối (strip)." Example="&quot;Bệnh   đạo ôn\n\n\n\nlá lúa  &quot; → &quot;Bệnh đạo ôn\n\nlá lúa&quot;." id="E3ZZzQtPJ33DhWGTJoaW-3">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="220" y="270" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-18" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="E3ZZzQtPJ33DhWGTJoaW-6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Chunking&lt;/font&gt;" Chunking="Cắt tài liệu dài thành các đoạn nhỏ bằng thuật toán Recursive Character Text Splitter — thử tách theo \n\n trước, nếu còn quá dài thì xuống \n, rồi theo câu, từ, cuối cùng mới cắt thô. Tối đa 512 ký tự/chunk, 64 ký tự overlap giữa 2 chunk liền kề để không mất ngữ cảnh tại điểm nối." Example="(minh hoạ với chunk_size=20, overlap=5):&#xa;  Gốc: &quot;AAAAAAAAAA BBBBBBBBBB CCCCCCCCCC&quot;&#xa;  → Chunk 1: &quot;AAAAAAAAAA BBBBB&quot; (20 ký tự)&#xa;  → Chunk 2: &quot;BBBBB CCCCCCCCCC&quot; (bắt đầu từ 5 ký tự overlap của chunk 1).&#xa;  Thực tế: một bài ~1500 ký tự → khoảng 3–4 chunk, mỗi chunk ≤ 512 ký tự, kế thừa metadata (crop, disease_name, source_name)." Role="Cắt mỗi tài liệu dài thành các đoạn nhỏ (chunk) có chồng lấn (overlap), vừa cỡ để embedding mà vẫn giữ ngữ cảnh." Algorithm="Recursive split (tương đương RecursiveCharacterTextSplitter của LangChain): thử cắt theo bộ phân tách từ thô → mịn: [&quot;\n\n&quot;,&#xa;  &quot;\n&quot;, &quot;. &quot;, &quot;! &quot;, &quot;? &quot;, &quot;; &quot;, &quot;, &quot;, &quot; &quot;, &quot;&quot;]. Cắt theo dấu thô nhất trước để giữ trọn ý; đoạn nào vẫn &gt; chunk_size thì đệ quy với dấu mịn hơn; bí quá thì cắt cứng theo ký tự. Các mảnh được gộp thành cửa sổ ≤ 512 ký tự, lặp lại 64 ký tự cuối của chunk trước sang đầu chunk sau (overlap), bỏ chunk ngắn &lt; ~80 ký tự. Mỗi chunk có chunk_id = sha256(source::index::text[:64])[:16] → xác định, nên reindex lại cùng file không tạo vector trùng." id="E3ZZzQtPJ33DhWGTJoaW-5">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="220" y="390" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-19" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="E3ZZzQtPJ33DhWGTJoaW-7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Embedding&lt;/font&gt;" Role="Biến mỗi chunk văn bản thành một vector số để máy so khớp theo ngữ nghĩa (chứ không chỉ theo từ khoá)." Algorithm="tilingual-e5-base (Sentence-Transformers), sinh vector 768 chiều, được chuẩn hoá L2 (để dùng cosine similarity).&#xa;  Đặc thù dòng e5: thêm tiền tố &quot;passage: &quot; cho tài liệu (và &quot;query: &quot; cho câu hỏi lúc truy vấn) — bắt buộc để mô hình hoạt động đúng. Encode theo&#xa;  batch 32, max_length=512 token, tự chọn thiết bị (CUDA &gt; MPS &gt; CPU), có LRU cache tránh embedding lại text trùng." Example="&quot;passage: Bệnh đạo ôn do nấm Pyricularia oryzae gây ra...&quot; → [0.013, -0.052, 0.087, ..., 0.006] (768 số thực, độ dài vector = 1). Hai đoạn&#xa;  cùng nói về &quot;đạo ôn&quot; sẽ có vector gần nhau (cosine cao)." id="E3ZZzQtPJ33DhWGTJoaW-6">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="220" y="500" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-22" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="E3ZZzQtPJ33DhWGTJoaW-21" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;span style=&quot;font-size: 18px;&quot;&gt;Qdrant&lt;/span&gt;" VectorDatabase="Cơ sở dữ liệu vector — lưu vector của mọi chunk kèm payload (metadata) và phục vụ tìm kiếm tương đồng (dense search) cực nhanh." Collection="Collection plant_diseases_vn, VectorParams(size=768, distance=COSINE). Mỗi điểm (point) lưu: id = chunk_id, vector 768d, và payload = {text, source, filename, chunk_index, chunk_total, timestamp, crop, disease_name, source_name, doc_type}. Khi reindex chạy với recreate_collection=True → xoá rồi tạo lại collection trước khi nạp (tránh dữ liệu cũ lẫn vào). Truy vấn: tính cosine giữa vector câu hỏi và các point, trả về gần nhất; có thể lọc theo crop ngay trong payload." Example="Point id=&quot;a1b2c3d4...&quot;, vector=[...768...], payload={crop:&quot;lúa&quot;, disease_name:&quot;bệnh đạo ôn lá&quot;, source_name:&quot;https://...&quot;, text:&quot;Bệnh đạo&#xa;  ôn...&quot;}." id="E3ZZzQtPJ33DhWGTJoaW-7">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="220" y="610" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-26" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="E3ZZzQtPJ33DhWGTJoaW-14">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Query&lt;/font&gt;" User="Đưa câu hỏi (chưa embedding)" Example="&quot;Nguyên nhân gây bệnh là gì?&quot;" id="E3ZZzQtPJ33DhWGTJoaW-8">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="600" y="40" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-31" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="E3ZZzQtPJ33DhWGTJoaW-25">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Dense Retrivel&lt;/font&gt;" Role="Lấy các chunk gần nghĩa nhất từ Qdrant, có lọc theo cây trồng." Algorithm="Tìm cosine similarity trên Qdrant; top_k mặc định 5 (trong hybrid lấy fetch_k = 3×top_k, tối thiểu 30 để tăng recall), bỏ chunk có điểm &lt; score_threshold = 0.30; lọc payload crop để chỉ lấy tài liệu đúng cây. Đây là bi-encoder (so vector–vector, rất nhanh)." id="E3ZZzQtPJ33DhWGTJoaW-9">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="480" y="260" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-35" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="E3ZZzQtPJ33DhWGTJoaW-11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Reranking&lt;/font&gt;" Role="Chấm lại độ liên quan thật giữa câu hỏi và từng chunk, loại nhiễu, giữ 3 chunk tốt nhất." Algorithm="Cross-encoder cross-encoder/mmarco-mMiniLMv2-L12-H384-v1 (đa ngữ, có tiếng Việt, chạy CPU). Đưa cặp (câu hỏi, đoạn văn) qua mô hình → điểm liên quan, sắp xếp giảm dần, cắt top_k = 3. Khác bi-encoder ở chỗ cross-encoder đọc đồng thời câu hỏi + đoạn nên chính xác hơn nhưng chậm → chỉ chạy trên số ít ứng viên RRF trả về." Example="~15 ứng viên sau RRF → cross-encoder chấm → giữ 3 chunk điểm cao nhất (vd 8.7, 6.2, 5.1), đúng trọng tâm câu hỏi nhất." id="E3ZZzQtPJ33DhWGTJoaW-10">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="590" y="490" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-36" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="E3ZZzQtPJ33DhWGTJoaW-12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;span style=&quot;font-size: 18px;&quot;&gt;Prompt builder&lt;/span&gt;" Role="Dựng prompt cuối cho LLM, ghim ngữ cảnh và nguồn để chống bịa." Algorithm="Ghép system prompt (vai trò trợ lý nông nghiệp; chỉ trả lời dựa trên [NGỮ CẢNH]; không bịa tên thuốc/liều; ưu tiên phòng ngừa; cuối bài thêm dòng Nguồn tham khảo:) + [LỊCH SỬ HỘI THOẠI] (tối đa 3 lượt gần nhất) + [NGỮ CẢNH] đánh số &quot;[i] (Nguồn: &lt;source_name&gt;)\n&lt;text&gt;&quot; + [CÂU HỎI]." Example="[NGỮ CẢNH]&#xa;  [1] (Nguồn: https://...benh-dao-on)&#xa;  Bệnh đạo ôn cổ bông do nấm Pyricularia oryzae...&#xa;&#xa;  [CÂU HỎI]&#xa;  Bệnh này chữa thế nào?" id="E3ZZzQtPJ33DhWGTJoaW-11">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="590" y="600" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-38" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="E3ZZzQtPJ33DhWGTJoaW-37">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;LLM&lt;/font&gt;" Role="Sinh câu trả lời tiếng Việt, dễ hiểu, chỉ dựa trên ngữ cảnh." Model="Qwen 2.5" id="E3ZZzQtPJ33DhWGTJoaW-12">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="590" y="710" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-28" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="E3ZZzQtPJ33DhWGTJoaW-9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Embedding Query&lt;/font&gt;" Role="Biến câu hỏi thành vector số để tìm theo ngữ nghĩa." Algorithm="Mô hình intfloat/multilingual-e5-base, 768 chiều, chuẩn hoá L2 (cosine). Đặc thù e5: thêm tiền tố &quot;query: &quot; (lúc ingest dùng &quot;passage:&quot;) — cặp prefix bất đối xứng này là yêu cầu của mô hình. Cùng một model với Phase ingest nên vector câu hỏi và vector tài liệu nằm chung không gian, so sánh được." Example="&quot;query: bệnh đạo ôn cổ bông Bệnh này chữa thế nào?&quot; → [0.021, -0.044, …, 0.009] (768 số, ‖v‖=1)." id="E3ZZzQtPJ33DhWGTJoaW-14">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="600" y="160" as="geometry" />
          </mxCell>
        </object>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;BM25 Index&lt;/font&gt;" Role="Bộ truy hồi theo từ khoá, bổ trợ cho vector ngữ nghĩa — tạo thành hybrid search. Mạnh khi người dùng gõ đúng thuật ngữ (vd &quot;đạo ôn&quot;, &quot;rầy nâu&quot;) mà dense có thể bỏ sót." Algorithm="BM25Okapi (thư viện rank_bm25). Điểm mấu chốt: index không dựng trực tiếp từ Chunking mà được dựng sau khi upsert, bằng cách&#xa;  scroll_all() đọc ngược toàn bộ chunk từ Qdrant ra → đảm bảo BM25 và Qdrant luôn cùng một tập dữ liệu. Tách từ đơn giản: lowercase + tách theo&#xa;  khoảng trắng. Công thức tính điểm cho mỗi chunk D với truy vấn Q:&#xa;  score(D,Q) = Σ IDF(qᵢ) · [ f(qᵢ,D)·(k₁+1) ] / [ f(qᵢ,D) + k₁·(1 − b + b·|D|/avgdl) ] (mặc định k₁=1.5, b=0.75) — tức ưu tiên chunk chứa nhiều từ&#xa;  khoá hiếm, có chuẩn hoá độ dài. Index được pickle ra data/bm25_index.pkl để nạp lại sau khi khởi động." Example="Truy vấn &quot;đạo ôn&quot; → token [&quot;đạo&quot;,&quot;ôn&quot;] → BM25 chấm điểm tất cả chunk, trả về top chunk chứa cụm &quot;đạo ôn&quot; với điểm cao nhất (chunk không có từ nào → điểm 0, bị loại)." id="E3ZZzQtPJ33DhWGTJoaW-21">
          <mxCell parent="1" style="whiteSpace=wrap;html=1;rounded=1;" vertex="1">
            <mxGeometry height="60" width="120" x="220" y="710" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-32" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="E3ZZzQtPJ33DhWGTJoaW-25">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;BM25 Retrivel&lt;/font&gt;" Role="Lấy chunk khớp từ khoá chính xác — bổ trợ cho ngữ nghĩa, mạnh với thuật ngữ (&quot;đạo ôn&quot;, &quot;rầy nâu&quot;)." Algorithm="BM25Okapi (TF-IDF có chuẩn hoá độ dài, mặc định k₁=1.5, b=0.75). Tokenize đơn giản: lowercase + tách khoảng trắng. Nhận thẳng text câu hỏi (không cần embedding) và chạy không lọc metadata (chỉ mục BM25 không lưu metadata) — nhiễu sẽ được Reranking loại sau." Example="&quot;đạo ôn&quot; → token [&quot;đạo&quot;,&quot;ôn&quot;] → trả chunk chứa đúng cụm &quot;đạo ôn&quot; với điểm BM25 cao nhất; chunk không chứa từ nào → điểm 0, bị loại." id="E3ZZzQtPJ33DhWGTJoaW-23">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="710" y="260" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-34" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="E3ZZzQtPJ33DhWGTJoaW-10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;RRF Fusion&lt;/font&gt;" Role="Hợp nhất 2 bảng xếp hạng (dense + BM25) thành một danh sách duy nhất." Algorithm="Reciprocal Rank Fusion (Cormack 2009): score(d) = α·1/(k + r_dense) + (1−α)·1/(k + r_bm25), với k=60, α=0.7 (trọng số cho dense, 0.3 cho BM25). Dùng thứ hạng chứ không dùng điểm thô → khỏi cần chuẩn hoá hai thang điểm khác nhau. Chunk vắng mặt ở một danh sách thì đóng góp 0 từ phía đó (không bị phạt)." Example="Chunk X hạng 1 ở dense, hạng 3 ở BM25 → 0.7·(1/61) + 0.3·(1/63) = 0.01148 + 0.00476 = 0.01624 → xếp trên một chunk chỉ xuất hiện ở một nguồn." id="E3ZZzQtPJ33DhWGTJoaW-25">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="590" y="370" as="geometry" />
          </mxCell>
        </object>
        <mxCell id="E3ZZzQtPJ33DhWGTJoaW-27" edge="1" parent="1" source="E3ZZzQtPJ33DhWGTJoaW-8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.6;entryY=-0.025;entryDx=0;entryDy=0;entryPerimeter=0;" target="E3ZZzQtPJ33DhWGTJoaW-23">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="&lt;font style=&quot;font-size: 18px;&quot;&gt;Output&lt;/font&gt;" id="E3ZZzQtPJ33DhWGTJoaW-37">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="60" width="120" x="590" y="800" as="geometry" />
          </mxCell>
        </object>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
